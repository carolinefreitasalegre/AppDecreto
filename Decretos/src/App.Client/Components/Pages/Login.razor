    @page "/login"
    @layout LoginLayout
    @rendermode InteractiveServer


    <RadzenRow Gap="0" 
               class="rz-my-12 rz-mx-auto rz-border-radius-6 rz-shadow-10" 
               Style="width: 100%; max-width: 800px; min-height: 500px; display: flex; overflow: hidden;">

        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard class="rz-shadow-0 rz-border-radius-0 rz-text-align-center rz-p-12" 
                        Style="height: 100%;
                               background: linear-gradient(135deg, #3AACFF 0%, #483AFF 50%, #FF1A6C 100%);
                               display: flex;
                               flex-direction: column;
                               align-items: center;
                               justify-content: center;">
                <RadzenText TextStyle="TextStyle.DisplayH3" TagName="TagName.H2" class="rz-color-white rz-mb-6">Bem-vindo!</RadzenText>
                <RadzenText TextStyle="TextStyle.H6" class="rz-color-white rz-mb-4">Sistema de Decretos</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-white">Faça login para continuar.</RadzenText>
            </RadzenCard>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H2" class="rz-mb-6">
                Login
            </RadzenText>
            <RadzenCard class="rz-shadow-0 rz-border-radius-0 rz-p-12"
                        Style="height: 100%; display: flex; flex-direction: column; justify-content: center;">


                <input type="text" placeholder="Usuário" style="width:100%; padding: 8px; margin-bottom: 1rem;"/>
                <input type="password" placeholder="Senha" style="width:100%; padding: 8px; margin-bottom: 1rem;"/>
                <button style="width:100%; padding: 8px;">Entrar</button>

            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
    
    
    @code {
        private string username = "";
        private string password = "";

        private void HandleLogin()
        {
            // aqui você vai chamar sua API
        }
    }